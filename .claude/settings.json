{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__figma-web__get_design_context",
      "mcp__figma-web__get_metadata",
      "WebFetch(domain:www.figma.com)",
      "mcp__figma-web__get_screenshot",
      "Bash(grep -r \"highlightedValue\\\\|highlightedId\" \"node_modules/.pnpm/@zag-js+menu@1\"*/node_modules/@zag-js/menu/dist/*.d.ts)",
      "Bash(grep -r \"RootProps\" node_modules/@ark-ui/react/dist/menu*.d.ts)",
      "mcp__claude_ai_Figma__get_design_context",
      "Bash(npx tsc --noEmit --project packages/design-system/tsconfig.json)",
      "Bash(git add .claude/settings.json)",
      "Bash(npx eslint packages/design-system/src/components/filter/FilterField/FilterField.tsx)",
      "Bash(npx eslint src/components/filter/FilterField/FilterField.tsx)",
      "Bash(git commit:*)",
      "Bash(pnpm --filter @wallarm-org/ui-kit exec tsc --noEmit)",
      "Bash(pnpm --filter design-system exec tsc --noEmit)",
      "Bash(npx tsc --noEmit)",
      "Bash(pnpm turbo run test --filter=design-system -- --run --reporter=verbose)",
      "Bash(npx vitest run --reporter=verbose)",
      "Bash(git mv FilterComposition.e2e.ts-snapshots __tests__/FilterComposition.e2e.ts-snapshots)",
      "Bash(git checkout HEAD -- packages/design-system/src/components/filter/FilterChip.stories.tsx packages/design-system/src/components/filter/FilterComposition.stories.tsx packages/design-system/src/components/filter/FilterField.stories.tsx packages/design-system/src/components/filter/FilterOperatorMenu.stories.tsx packages/design-system/src/components/filter/primitives/SegmentAttribute.stories.tsx packages/design-system/src/components/filter/primitives/SegmentOperator.stories.tsx packages/design-system/src/components/filter/primitives/SegmentValue.stories.tsx)",
      "Bash(git checkout HEAD -- packages/design-system/src/components/filter/FilterChip/FilterChip.stories.tsx packages/design-system/src/components/filter/FilterField/FilterField.stories.tsx packages/design-system/src/components/filter/FilterOperatorMenu/FilterOperatorMenu.stories.tsx packages/design-system/src/components/filter/segments/SegmentAttribute.stories.tsx packages/design-system/src/components/filter/segments/SegmentOperator.stories.tsx packages/design-system/src/components/filter/segments/SegmentValue.stories.tsx packages/design-system/src/components/filter/FilterComposition.stories.tsx)",
      "Bash(git status -u)"
    ]
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "ralph-skills@ralph-marketplace": true
  }
}
